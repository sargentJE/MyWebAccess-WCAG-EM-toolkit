{
  "name": "legacy-events",
  "rootUrl": "https://legacy-events.com/",
  "scope": {
    "mode": "same-hostname",
    "allowedHosts": []
  },
  "crawl": {
    "maxPages": 80,
    "maxConcurrency": 5,
    "requestTimeoutSecs": 90,
    "requestDelayMs": 500,
    "excludeUrlPatterns": ["/wp-admin", "\\?replytocom=", "/feed/?$"],
    "sitemapSeeding": {
      "enabled": true,
      "urls": [],
      "commonPaths": ["/sitemap.xml", "/sitemap_index.xml"],
      "maxUrls": 500
    }
  },
  "discovery": {
    "captureH1": true,
    "captureCanonical": true,
    "captureForms": true,
    "captureLandmarks": true,
    "captureSearchInputs": true
  },
  "sample": {
    "structuredManual": [
      "https://legacy-events.com/",
      "https://legacy-events.com/about/",
      "https://legacy-events.com/contact-us/",
      "https://legacy-events.com/privacy-policy/",
      "https://legacy-events.com/sustainability/",
      "https://legacy-events.com/what-we-do/",
      "https://legacy-events.com/what-we-do/event-management/",
      "https://legacy-events.com/what-we-do/strategy-training/",
      "https://legacy-events.com/what-we-do/sourcing/",
      "https://legacy-events.com/what-we-do/event-management/collaboration-exchange/",
      "https://legacy-events.com/our-work/",
      "https://legacy-events.com/our-work/100-together-conference-2024/",
      "https://legacy-events.com/legacy-labs/",
      "https://legacy-events.com/latest/",
      "https://legacy-events.com/latest/why-we-changed-our-name/"
    ],
    "autoSuggest": {
      "enabled": true,
      "perCluster": 1,
      "preferTypes": ["homepage", "form-or-contact", "policy", "listing", "detail", "content"]
    },
    "randomPercentOfStructured": 0.1,
    "minRandomPages": 2,
    "randomSeed": 1,
    "smallSiteSupplementaryScanThreshold": 50
  },
  "scan": {
    "viewports": [
      { "id": "desktop", "width": 1280, "height": 800 },
      { "id": "reflow", "width": 320, "height": 800 }
    ],
    "waitUntil": "domcontentloaded",
    "timeoutMs": 60000,
    "retries": 1,
    "fullPageScreenshots": true,
    "axe": {
      "include": [],
      "exclude": [],
      "withRules": [],
      "withTags": ["wcag2a", "wcag2aa", "wcag21a", "wcag21aa", "wcag22aa", "best-practice"],
      "runOnly": null
    }
  },
  "processes": [
    {
      "name": "contact-blank-submit",
      "startUrl": "https://legacy-events.com/contact-us/",
      "pattern": "blank-submit",
      "forceInclude": true,
      "selectors": {
        "submit": "button[type='submit'], input[type='submit']"
      }
    }
  ],
  "reporting": {
    "reporters": ["json", "markdown", "html", "earl-jsonld", "junit"],
    "groupBestPracticeSeparately": true,
    "failOnFindings": {
      "impacts": ["critical", "serious"],
      "classifications": [],
      "threshold": 1
    }
  },
  "wcagEm": {
    "wcagVersion": "2.2",
    "conformanceTarget": "AA",
    "atBaseline": [],
    "technologiesReliedUpon": ["HTML", "CSS", "JavaScript", "WAI-ARIA"],
    "samplingMethodNotes": "Structured sample (WCAG-EM Step 3a) curated by the auditor — homepage, about, contact, privacy policy, sustainability, what-we-do (incl. three service pages + collaboration-exchange sub-page), our-work (incl. one case study), legacy-labs landing, latest blog listing + one post. 15 pages covering all distinct page types. Supplemented by toolkit auto-suggest (top page-type per cluster) and a 10% random pool.",
    "evaluator": {
      "name": "Jamie Sargent",
      "contact": "support@mwebaccess.co.uk"
    }
  }
}
